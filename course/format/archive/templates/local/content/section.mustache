{{!
    @template format_archive/local/content/section

    Overrides core_courseformat/local/content/section for the archive format.
    Adds the "archive-separator" class to sections with isseparator=1.
}}
<li id="section-{{num}}"
    class="section course-section main archive-section {{#onlysummary}} section-summary {{/onlysummary}} clearfix
            {{#ishidden}} hidden {{/ishidden}} {{#iscurrent}}{{^displayonesection}} current {{/displayonesection}}{{/iscurrent}}
            {{#isstealth}} orphaned {{/isstealth}}
            {{#isseparator}} archive-separator {{/isseparator}}"
    data-sectionid="{{num}}"
    data-sectionreturnnum="{{sectionreturnnum}}"
    data-for="section"
    data-id="{{id}}"
    data-number="{{num}}"
    data-sectionname="{{sectionname}}"
    {{#isseparator}} data-isseparator="1" {{/isseparator}}
    {{#isstealth}} data-orphan="true" {{/isstealth}}
>
    <div class="section-item">
        {{$ core_courseformat/local/content/section/content }}
            {{> core_courseformat/local/content/section/content }}
        {{/ core_courseformat/local/content/section/content }}
    </div>

    {{#insertafter}}
        {{#numsections}}
            {{$ core_courseformat/local/content/addsection}}
                {{> core_courseformat/local/content/section/addsectiondivider }}
            {{/ core_courseformat/local/content/addsection}}
        {{/numsections}}
    {{/insertafter}}
</li>
