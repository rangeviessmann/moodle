{{!
    @template local_activityreport/filter_form

    Filter form for activity report.

    Context variables required for this template:
    * actionurl    - Form action URL
    * reseturl     - Reset filters URL
    * exporturl    - CSV export URL (with current filters)
    * fields       - Array of filter field objects with id, name, label, type, value
    * str_filter   - Filter button label
    * str_reset    - Reset button label
    * str_exportcsv - Export CSV button label

    Example context (json):
    {
        "actionurl": "/local/activityreport/index.php",
        "reseturl": "/local/activityreport/index.php",
        "exporturl": "/local/activityreport/index.php?download=csv",
        "fields": [
            {"id": "filter_firstname", "name": "filter_firstname", "label": "First name", "type": "text", "value": ""},
            {"id": "filter_eventname", "name": "filter_eventname", "label": "Event name", "type": "select", "is_select": true, "value": "",
             "options": [{"value": "", "label": "— All events —", "selected": true}]}
        ],
        "str_filter": "Filter",
        "str_reset": "Reset filters",
        "str_exportcsv": "Export CSV"
    }
}}
<form method="get" action="{{{actionurl}}}" class="mb-3">
    {{#hidden_fields}}
    <input type="hidden" name="{{name}}" value="{{value}}">
    {{/hidden_fields}}
    <div class="d-flex flex-wrap align-items-end gap-2 mb-2">
        {{#fields}}
        <div class="form-group mb-0">
            <label for="{{id}}" class="small mb-1">{{label}}</label>
            {{#is_select}}
            <select id="{{id}}" name="{{name}}" class="form-control form-control-sm">
                {{#options}}
                <option value="{{value}}"{{#selected}} selected{{/selected}}>{{label}}</option>
                {{/options}}
            </select>
            {{/is_select}}
            {{^is_select}}
            <input type="{{type}}" id="{{id}}" name="{{name}}" class="form-control form-control-sm" value="{{value}}">
            {{/is_select}}
        </div>
        {{/fields}}
    </div>
    <div class="d-flex align-items-center gap-2 mt-2">
        <button type="submit" class="btn btn-primary btn-sm">{{str_filter}}</button>
        <a href="{{{reseturl}}}" class="btn btn-secondary btn-sm">{{str_reset}}</a>
        {{#exporturl}}
        <a href="{{{exporturl}}}" class="btn-primary btn btn-sm ms-auto">
            <i class="fa fa-download me-1" aria-hidden="true"></i>{{str_exportcsv}}
        </a>
        {{/exporturl}}
    </div>
</form>
